```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Test cache
.pytest_cache/

# Logs
*.log

# Environment files
.env
.env.local
*.env.*

# Dependencies
venv/
.venv/
.env/

# Build artifacts
build/
dist/
target/

# Coverage reports
.coverage
htmlcov/
coverage/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# System files
.DS_Store
Thumbs.db

# MyPy cache
.mypy_cache/

# Gradle
.gradle/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```