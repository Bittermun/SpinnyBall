```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
.venv/
venv/
env/
.env
.env.local
.env.*

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Build and distribution
dist/
build/
target/

# Testing
.pytest_cache/
.coverage
coverage/

# System files
.DS_Store
Thumbs.db
```