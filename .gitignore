```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs
*.log

# Environment files
.env
.env.local
*.env.*

# Dependencies
.venv/
venv/
node_modules/

# Build artifacts
dist/
build/
target/

# Coverage reports
.coverage
coverage/
htmlcov/

# Editors
.vscode/
.idea/

# System files
.DS_Store
Thumbs.db
```