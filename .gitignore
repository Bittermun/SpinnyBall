```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled Python files
*.cpython-*.pyc

# Logs and temporary files
*.log
*.tmp
*.swp

# Environment files
.env
.env.local
*.env.*

# Coverage reports
.coverage
htmlcov/
coverage/

# IDE specific files
.vscode/
.idea/
*.swp
*.swo

# OS specific files
.DS_Store
Thumbs.db
```