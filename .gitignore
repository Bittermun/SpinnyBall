```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled Python files
*.cpython-312.pyc
*.cpython-*.pyc

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Environment files
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo

# Coverage reports
.coverage
coverage/
htmlcov/

# Distribution / packaging
dist/
build/
*.egg-info/
```